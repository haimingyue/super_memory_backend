# 应用配置
APP_NAME=Super Memory API
APP_VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 阿里云通义千问配置
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-turbo

# LangChain 配置
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# 数据库配置
DATABASE_URL=sqlite:///./super_memory.db
